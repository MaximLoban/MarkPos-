<Window x:Class="MarkPos.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MarkPos.UI"
        xmlns:local="clr-namespace:MarkPos.UI"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        
        mc:Ignorable="d"
        Title="MarkPos"
        WindowState="Maximized"
        WindowStyle="None"
        Background="#F5F5F5"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="Green"    Color="#8DC640"/>
        <SolidColorBrush x:Key="Graphite" Color="#373C46"/>
        <SolidColorBrush x:Key="Red"      Color="#DE3030"/>
        <SolidColorBrush x:Key="LightBg"  Color="#F2F2F2"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
   

        <!-- Ползунок скроллбара -->
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="Height" Value="108"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#9EA6B5"
                        CornerRadius="18"
                        Margin="3,0">
                            <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                                <Border Height="2" Width="20" Background="White"
                                Opacity="0.8" Margin="0,4" CornerRadius="1"/>
                                <Border Height="2" Width="20" Background="White"
                                Opacity="0.8" Margin="0,4" CornerRadius="1"/>
                                <Border Height="2" Width="20" Background="White"
                                Opacity="0.8" Margin="0,4" CornerRadius="1"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Скроллбар -->
        <Style x:Key="CartScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="46" Background="#CFD0CF">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>

                            <!-- Стрелка вверх -->
                            <RepeatButton Grid.Row="0"
                                  Command="ScrollBar.LineUpCommand"
                                  Focusable="False">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border Background="#CFD0CF">
                                            <Border Width="36" Height="36"
                                            Background="#9EA6B5"
                                            CornerRadius="18"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                                <Viewbox Width="12" Height="8">
                                                    <Path Data="M 0,7 L 6,1 L 12,7"
                                                  Stroke="White"
                                                  StrokeThickness="2.5"
                                                  StrokeLineJoin="Round"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Fill="Transparent"/>
                                                </Viewbox>
                                            </Border>
                                        </Border>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>

                            <!-- Трек с ползунком -->
                            <Border Grid.Row="1" Background="#CFD0CF">
                                <Track x:Name="PART_Track"
                               IsDirectionReversed="True"
                               Focusable="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageUpCommand"
                                              Opacity="0" Focusable="False"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageDownCommand"
                                              Opacity="0" Focusable="False"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>

                            <!-- Стрелка вниз -->
                            <RepeatButton Grid.Row="2"
                                  Command="ScrollBar.LineDownCommand"
                                  Focusable="False">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border Background="#CFD0CF">
                                            <Border Width="36" Height="36"
                                            Background="#9EA6B5"
                                            CornerRadius="18"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                                <Viewbox Width="12" Height="8">
                                                    <Path Data="M 0,1 L 6,7 L 12,1"
                                                  Stroke="White"
                                                  StrokeThickness="2.5"
                                                  StrokeLineJoin="Round"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Fill="Transparent"/>
                                                </Viewbox>
                                            </Border>
                                        </Border>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollViewer -->
        <Style x:Key="CartScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="46"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"
                                            CanContentScroll="True"
                                            Content="{TemplateBinding Content}"
                                            ContentTemplate="{TemplateBinding ContentTemplate}"/>
                            <ScrollBar Grid.Column="1"
                               x:Name="PART_VerticalScrollBar"
                               Style="{StaticResource CartScrollBar}"
                               Orientation="Vertical"
                               Value="{TemplateBinding VerticalOffset}"
                               Maximum="{TemplateBinding ScrollableHeight}"
                               ViewportSize="{TemplateBinding ViewportHeight}"
                               Visibility="Visible"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="93"/>
            <!-- Хедер -->
            <RowDefinition Height="Auto"/>
            <!-- Инфо-полоска -->
            <RowDefinition Height="*"/>
            <!-- Контент -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="640"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════ ХЕДЕР ══════════ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="White">
            <Grid Margin="27,0">
                <Image Source="C:\MarketPosSale\data4\Image\MainLogin\logo.png"
                       Height="38" HorizontalAlignment="Left"
                       VerticalAlignment="Center" Stretch="Uniform"/>
                <controls:AdminButton HorizontalAlignment="Right"
                                      VerticalAlignment="Center"/>
                <TextBox x:Name="BarcodeInput"
                         Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="BarcodeInput_KeyDown"
                         Width="1" Height="1" Opacity="0"/>
            </Grid>
        </Border>

        <!-- ══════════ ИНФО-ПОЛОСКА ══════════ -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                Padding="20,10"
                Visibility="{Binding HasInfoMessage, Converter={StaticResource BoolToVis}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsInfoWarning}" Value="True">
                            <Setter Property="Background" Value="#FFF3CD"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsInfoWarning}" Value="False">
                            <Setter Property="Background" Value="#D4EDDA"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding InfoMessage}"
                       FontFamily="Open Sans" FontSize="20"
                       HorizontalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInfoWarning}" Value="True">
                                <Setter Property="Foreground" Value="#856404"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsInfoWarning}" Value="False">
                                <Setter Property="Foreground" Value="#155724"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

        <!-- ══════════ ЛЕВАЯ ЧАСТЬ ══════════ -->
        <Grid Grid.Row="2" Grid.Column="0" Background="#F5F5F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Полоска дисконтной карты — всегда видна -->
            <Border Grid.Row="0" Background="White"
        BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
        Padding="27,10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="C:\MarketPosSale\data4\Image\CreditDoc\DiscountCard.png"
               Width="80" Height="50"
               Stretch="Uniform" Margin="0,0,16,0">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDiscountCard}" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock FontFamily="Open Sans" FontSize="20"
                   Foreground="{StaticResource Graphite}"
                   VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding DiscountCardText}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDiscountCard}" Value="False">
                                        <Setter Property="Text" Value="Отсканируйте Вашу дисконтную карту «Е-плюс»"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Карточка текущего товара — всегда видна, фиксированная высота -->
            <Border Grid.Row="1" Background="White" Margin="0,10,0,0" Height="250"
        x:Name="CurrentItemCard">
                <Border.RenderTransform>
                    <TranslateTransform X="0" Y="0"/>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                        Storyboard.TargetProperty=
                            "(UIElement.RenderTransform).(TranslateTransform.Y)"
                        From="-30" To="0"
                        Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation
                        Storyboard.TargetProperty="Opacity"
                        From="0" To="1"
                        Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="255"/>
                        <!-- Фото на всю высоту -->
                        <ColumnDefinition Width="*"/>
                        <!-- Контент -->
                    </Grid.ColumnDefinitions>

                    <!-- Фото товара — на всю высоту карточки -->

                    <Border Grid.Column="0"
        Background="#F5F5F5"
        VerticalAlignment="Stretch"
        HorizontalAlignment="Stretch"
        ClipToBounds="True">
                        <Image Stretch="UniformToFill"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"
           Source="{Binding CurrentItemImagePath}">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentItemImagePath}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                    </Border>

                    <!-- Правая часть: название+удалить / разделитель / цена+кол-во+итого -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <!-- Название + удалить -->
                            <RowDefinition Height="1"/>
                            <!-- Разделитель -->
                            <RowDefinition Height="Auto"/>
                            <!-- Цена / Кол-во / Итого -->
                        </Grid.RowDefinitions>

                        <!-- Название + кнопка удалить -->
                        <Grid Grid.Row="0" Margin="20,14,20,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="148"/>
                            </Grid.ColumnDefinitions>

                            <!-- Название / плейсхолдер -->
                            <TextBlock Grid.Column="0"
                           FontFamily="Roboto" FontSize="30"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding CurrentItemName}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Graphite}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasCurrentItem}" Value="False">
                                                <Setter Property="Text" Value="ОТСКАНИРУЙТЕ ТОВАР"/>
                                                <Setter Property="FontSize" Value="36"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Кнопка УДАЛИТЬ -->
                            <Button Grid.Column="1"
                        Command="{Binding RemoveCurrentCommand}"
                        Width="148" Height="80"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        BorderThickness="0" Cursor="Hand"
                        Visibility="{Binding HasCurrentItem, Converter={StaticResource BoolToVis}}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{StaticResource Red}" CornerRadius="10">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="10" ShadowDepth="0"
                                                      Color="#000000" Opacity="0.2"/>
                                            </Border.Effect>
                                            <TextBlock Text="УДАЛИТЬ&#10;ТОВАР"
                                           FontFamily="Roboto" FontWeight="Bold"
                                           FontSize="20" Foreground="White"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- Разделитель -->
                        <Border Grid.Row="1" Height="1" Background="#E0E0E0"
                    Visibility="{Binding HasCurrentItem, Converter={StaticResource BoolToVis}}"/>

                        <!-- Цена / Кол-во / Итого -->
                        <Grid Grid.Row="2" Margin="20,10,20,14"
      Visibility="{Binding HasCurrentItem, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <!-- Цена — фиксированная -->
                                <ColumnDefinition Width="*"/>
                                <!-- Отступ -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Кол-во — по содержимому -->
                                <ColumnDefinition Width="*"/>
                                <!-- Отступ -->
                                <ColumnDefinition Width="160"/>
                                <!-- Итого — фиксированная -->
                            </Grid.ColumnDefinitions>

                            <!-- Цена -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                                <TextBlock Text="ЦЕНА, BYN" FontFamily="Roboto" FontWeight="Bold"
                               FontSize="16" Foreground="{StaticResource Graphite}"
                               Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CurrentItemPrice}" FontFamily="Roboto"
                               FontSize="40" Foreground="{StaticResource Graphite}"/>
                            </StackPanel>

                            <!-- Кол-во -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom"
                            HorizontalAlignment="Center">
                                <TextBlock Text="КОЛИЧЕСТВО, ШТ" FontFamily="Roboto" FontWeight="Bold"
                               FontSize="16" Foreground="{StaticResource Graphite}"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding DecreaseQtyCommand}"
                                Width="64" Height="64" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Image Source="C:\MarketPosSale\data4\Image\CreditDoc\CurrentQuantityMinus.png"
                                           Width="64" Height="64" Stretch="Uniform"/>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Border Width="200" Height="76" Background="#33D7D8DA"
                                BorderBrush="#8C969D" BorderThickness="1" Margin="12,0">
                                        <TextBlock Text="{Binding CurrentItemQty}" FontFamily="Roboto"
                                       FontSize="40" Foreground="{StaticResource Graphite}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Button Command="{Binding IncreaseQtyCommand}"
                                Width="64" Height="64" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Image Source="C:\MarketPosSale\data4\Image\CreditDoc\CurrentQuantityPlus.png"
                                           Width="64" Height="64" Stretch="Uniform"/>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <!-- Итого -->
                            <StackPanel Grid.Column="4" VerticalAlignment="Bottom"
            HorizontalAlignment="Right">
                                <TextBlock Text="ВСЕГО, BYN" FontFamily="Roboto" FontWeight="Bold"
               FontSize="16" Foreground="{StaticResource Graphite}"
               HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CurrentItemTotal}" FontFamily="Roboto"
               FontWeight="Bold" FontSize="40"
               Foreground="{StaticResource Graphite}"
               HorizontalAlignment="Right"/>
                                <!-- Фиксированная высота — не скачет когда скидка появляется/исчезает -->
                                <TextBlock FontFamily="Roboto" FontSize="20"
               HorizontalAlignment="Right"
               Height="28">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding CurrentItemDiscount}"/>
                                            <Setter Property="Foreground" Value="{StaticResource Graphite}"/>
                                            <Setter Property="Opacity" Value="0.4"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasCurrentItemDiscount}" Value="False">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- Таблица корзины -->
            <Border Grid.Row="2" Margin="0,10,0,0"
        Background="White"
        ClipToBounds="True"
        HorizontalAlignment="Stretch"
        MaxHeight="450">
                <Grid HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource Graphite}" CornerRadius="20,20,0,0">
                        <Grid HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="62"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="87"/>
                                <ColumnDefinition Width="133"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="В КОРЗИНЕ"
                                       FontFamily="Roboto" FontWeight="Bold" FontSize="16"
                                       Foreground="White" VerticalAlignment="Center" Margin="32,12,0,12"/>
                            <TextBlock Grid.Column="2" Text="ЦЕНА" FontFamily="Roboto" FontWeight="Bold"
                                       FontSize="16" Foreground="White" HorizontalAlignment="Left"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="КОЛ-ВО/ВЕС" FontFamily="Roboto"
                                       FontWeight="Bold" FontSize="16" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="ВСЕГО" FontFamily="Roboto" FontWeight="Bold"
                                       FontSize="16" Foreground="White" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" Margin="0,0,40,0"/>
                        </Grid>
                    </Border>
                    <ListView Grid.Row="1"
          ItemsSource="{Binding Lines}"
          Background="White"
          BorderThickness="0"
          HorizontalAlignment="Stretch"
          HorizontalContentAlignment="Stretch"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.Template>
                            <ControlTemplate TargetType="ListView">
                                <ScrollViewer Style="{StaticResource CartScrollViewer}"
                          CanContentScroll="False">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ListView.Template>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="White"/>
                               
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="{TemplateBinding Background}"
                                HorizontalAlignment="Stretch">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="0" ShadowDepth="1"
                                                  Direction="270" Color="#1C2D4F" Opacity="0.1"/>
                                                </Border.Effect>
                                                <ContentPresenter Margin="0,14" HorizontalAlignment="Stretch"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0FAE6"/>
                                    </Trigger>
                                    
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="42" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="62"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="87"/>
                                        <ColumnDefinition Width="133"/>
                                        <ColumnDefinition Width="110"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                           Text="{Binding LineNumber, StringFormat='{}{0:D2}.'}"
                           FontFamily="Open Sans" FontSize="20"
                           Foreground="#8C969D" Opacity="0.5"
                           HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="31,0,0,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Product.Name}"
                           FontFamily="Roboto" FontSize="20"
                           Foreground="{StaticResource Graphite}"
                           TextWrapping="Wrap" VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="2"
                           Text="{Binding PriceOld, StringFormat=F2}"
                           FontFamily="Roboto" FontSize="20"
                           Foreground="{StaticResource Graphite}"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3"
                           Text="{Binding Quantity, StringFormat=F1}"
                           FontFamily="Roboto" FontSize="20"
                           Foreground="{StaticResource Graphite}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="4" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,40,0">
                                        <TextBlock Text="{Binding TotalSum, StringFormat=F2}"
                               FontFamily="Roboto" FontWeight="Bold" FontSize="20"
                               Foreground="{StaticResource Graphite}"
                               HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding DiscountSum, StringFormat='-{0:F2}'}"
                               FontFamily="Roboto" FontSize="16"
                               Foreground="{StaticResource Graphite}" Opacity="0.4"
                               HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Итоги -->
            <Border Grid.Row="3" Background="{StaticResource Graphite}" Margin="0" Padding="31,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="СУММА БЕЗ УЧЁТА СКИДКИ:"
                               FontFamily="Open Sans" FontSize="18" Foreground="White"
                               Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SumWithoutDiscountText}"
                               FontFamily="Open Sans" FontSize="18" Foreground="White"
                               Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="ВАША СКИДКА ПО КАРТЕ «Е-ПЛЮС»:"
                               FontFamily="Open Sans" FontWeight="SemiBold" FontSize="18" Foreground="White"
                               Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DiscountSumText}"
                               FontFamily="Open Sans" FontWeight="SemiBold" FontSize="18" Foreground="White"
                               Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="ИТОГО К ОПЛАТЕ:"
                               FontFamily="Open Sans" FontWeight="SemiBold" FontSize="44"
                               Foreground="{StaticResource Green}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TotalText}"
                               FontFamily="Open Sans" FontWeight="SemiBold" FontSize="44"
                               Foreground="{StaticResource Green}" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════ ПРАВАЯ ПАНЕЛЬ ══════════ -->
        <Grid Grid.Row="2" Grid.Column="1" Background="#F5F5F5">
            <Grid Margin="54,0,0,0" Background="{StaticResource Graphite}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="320"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <!-- Подсказка: переключается по состоянию -->
                <Border Grid.Row="0" Background="{StaticResource LightBg}"
        CornerRadius="10" Margin="19,17,19,0"
        BorderBrush="#FFFDFD" BorderThickness="1">
                    <Grid>
                        <!-- Нет товара -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasCurrentItem}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Image Source="C:\MarketPosSale\data4\Image\CreditDoc\ScanerEmptyBascket.png"
               Width="200" Stretch="Uniform"
               HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Есть товар: Scaner.png на весь блок без текста -->
                        <Image VerticalAlignment="Stretch"
       HorizontalAlignment="Stretch"
       Stretch="Uniform"
       Margin="10">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Source"
                    Value="C:\MarketPosSale\data4\Image\CreditDoc\Scaner.png"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasCurrentItem}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                    </Grid>
                </Border>
                <!-- Кнопки -->
                <StackPanel Grid.Row="1">
                    <Border BorderBrush="#401C2D4F" BorderThickness="0,1,0,0"
                    Height="141" Background="{StaticResource Graphite}">
                        <Grid Margin="26,0,19,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0"
                           Source="C:\MarketPosSale\data4\Image\CreditDoc\GoodsSearch.png"
                           Width="70" Height="70" Stretch="Uniform"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="ИСКАТЬ В КАТАЛОГЕ"
                               FontFamily="Open Sans" FontWeight="Bold" FontSize="28"
                               Foreground="White" VerticalAlignment="Center" Margin="29,0,0,0"/>
                            <Image Grid.Column="2"
                           Source="C:\MarketPosSale\data4\Image\CreditDoc\ButtonArrow.png"
                           Width="28" Height="28" Stretch="Uniform"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border BorderBrush="#401C2D4F" BorderThickness="0,1,0,0"
                    Height="141" Background="{StaticResource Graphite}" Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding ScanCommand}"/>
                        </Border.InputBindings>
                        <Grid Margin="26,0,19,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0"
                           Source="C:\MarketPosSale\data4\Image\CreditDoc\BarcodeSearch.png"
                           Width="70" Height="70" Stretch="Uniform"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="ПОИСК ПО ШТРИХ-КОДУ"
                               FontFamily="Open Sans" FontWeight="Bold" FontSize="28"
                               Foreground="White" VerticalAlignment="Center" Margin="29,0,0,0"/>
                            <Image Grid.Column="2"
                           Source="C:\MarketPosSale\data4\Image\CreditDoc\ButtonArrow.png"
                           Width="28" Height="28" Stretch="Uniform"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border BorderBrush="#401C2D4F" BorderThickness="0,1,0,0"
                    Height="141" Background="{StaticResource Graphite}">
                        <Grid Margin="26,0,19,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0"
                           Source="C:\MarketPosSale\data4\Image\CreditDoc\BagAdd.png"
                           Width="82" Height="82" Stretch="Uniform"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="ДОБАВИТЬ ПАКЕТЫ"
                               FontFamily="Open Sans" FontWeight="Bold" FontSize="28"
                               Foreground="White" VerticalAlignment="Center" Margin="29,0,0,0"/>
                            <Image Grid.Column="2"
                           Source="C:\MarketPosSale\data4\Image\CreditDoc\ButtonArrow.png"
                           Width="28" Height="28" Stretch="Uniform"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ОПЛАТИТЬ -->
                <Button Grid.Row="2" Command="{Binding PayCommand}"
                BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{StaticResource Green}">
                                <TextBlock Text="ОПЛАТИТЬ"
                                   FontFamily="Open Sans" FontWeight="Bold"
                                   FontSize="60" Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>

        <!-- ══════════ ОВЕРЛЕЙ: УСПЕХ ══════════ -->
        <Grid Grid.Row="0" Grid.RowSpan="3" Grid.ColumnSpan="2"
      Background="#F5F5F5"
      d:Visibility="Collapsed"
      Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="93"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Хедер -->
            <Border Grid.Row="0" Background="White">
                <Grid Margin="27,0">
                    <Image Source="C:\MarketPosSale\data4\Image\MainLogin\logo.png"
                   Height="38" HorizontalAlignment="Left"
                   VerticalAlignment="Center" Stretch="Uniform"/>
                    <controls:AdminButton HorizontalAlignment="Right"
                                  VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Контент -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Lottie анимация + fallback -->
                <Grid Grid.Column="0"
          HorizontalAlignment="Center"
          VerticalAlignment="Center">
                    <Image Source="C:\MarketPosSale\data4\Image\Finish\Finish.png"
               Width="400" Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>
                    <ContentControl x:Name="LottieContainer"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="500"
                        Height="500"/>
                </Grid>

                <!-- Текст + кнопка -->
                <StackPanel Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                    <TextBlock Text="ЗАБЕРИТЕ ВАШ ЧЕК И ПОКУПКИ."
                   FontFamily="Open Sans" FontWeight="Bold"
                   FontSize="56" Foreground="{StaticResource Graphite}"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"/>
                    <TextBlock Text="ЖДЕМ ВАС СНОВА!"
                   FontFamily="Open Sans" FontWeight="Bold"
                   FontSize="56" Foreground="{StaticResource Green}"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,60"/>
                    <Button HorizontalAlignment="Center"
                Width="380" Height="90"
                BorderThickness="0"
                Cursor="Hand"
                Command="{Binding ClearSuccessCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{StaticResource Green}" CornerRadius="12">
                                    <TextBlock Text="НАЧАТЬ НОВУЮ ПОКУПКУ"
                                   FontFamily="Open Sans" FontWeight="Bold"
                                   FontSize="26" Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>


        <!-- ══════════ ОВЕРЛЕЙ: ОШИБКА ══════════ -->
        
        <Grid Grid.Row="0" Grid.RowSpan="3" Grid.ColumnSpan="2"
              Background="#F5F5F5"
              Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
d:Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="93"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White">
                <Grid Margin="27,0">
                    <Image Source="C:\MarketPosSale\data4\Image\MainLogin\logo.png"
                           Height="38" HorizontalAlignment="Left"
                           VerticalAlignment="Center" Stretch="Uniform"/>
                    <controls:AdminButton HorizontalAlignment="Right"
                                          VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <Image Source="C:\MarketPosSale\data4\Image\ShowMessageAttention\NotFindGood.png"
                       Width="658" Height="350" Stretch="Uniform"
                       HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <TextBlock FontFamily="Open Sans" FontWeight="Bold"
                  FontSize="64" Foreground="{StaticResource Graphite}"
                 TextAlignment="Center" HorizontalAlignment="Center"      
                 Margin="0,0,0,40">
                  <Run Text="{Binding ErrorMessage, Mode=OneWay}"/>
                </TextBlock>

                <Button HorizontalAlignment="Center" Width="280" Height="80"
                        BorderThickness="0" Background="Transparent"
                        Cursor="Hand" Command="{Binding ClearErrorCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent"
                                    BorderBrush="{StaticResource Red}"
                                    BorderThickness="4" CornerRadius="10">
                                <TextBlock Text="ЗАКРЫТЬ"
                                           FontFamily="Roboto" FontWeight="Bold"
                                           FontSize="24" Foreground="{StaticResource Red}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>

    </Grid>
</Window>