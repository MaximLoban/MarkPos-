<Window x:Class="MarkPos.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MarkPos — Касса самообслуживания"
        WindowState="Maximized"
        Background="#1E1E2E">

    <Window.Resources>
        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#00d4ff"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="КАССА САМООБСЛУЖИВАНИЯ"
                   Foreground="White" FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Список товаров -->
        <DataGrid Grid.Row="1"
                  x:Name="LinesGrid"
                  ItemsSource="{Binding Lines}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="#2E2E3E"
                  Foreground="White"
                  RowBackground="#2E2E3E"
                  AlternatingRowBackground="#3E3E4E"
                  BorderBrush="#555"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}"
                  FontSize="16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№"           Binding="{Binding LineNumber}"              Width="50"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Product.Name}"           Width="*"/>
                <DataGridTextColumn Header="Кол-во"      Binding="{Binding Quantity, StringFormat=F3}" Width="80"/>
                <DataGridTextColumn Header="Цена"        Binding="{Binding Price, StringFormat=F2}"  Width="100"/>
                <DataGridTextColumn Header="Скидка"      Binding="{Binding DiscountSum, StringFormat=F2}" Width="100"/>
                <DataGridTextColumn Header="Сумма"       Binding="{Binding TotalSum, StringFormat=F2}"    Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Поле сканирования и итог -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Штрихкод -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Отсканируйте товар или введите штрихкод:"
                           Foreground="#AAA" FontSize="14" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="BarcodeInput"
                             Grid.Column="0"
                             Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="20"
                             Padding="10"
                             Background="#2E2E3E"
                             Foreground="White"
                             CaretBrush="White"
                             BorderBrush="#555"
                             KeyDown="BarcodeInput_KeyDown"/>
                    <Button Grid.Column="1"
                            Content="Добавить"
                            Command="{Binding ScanCommand}"
                            Margin="10,0,0,0"
                            FontSize="16"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </Grid>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="#FF6B6B"
                           FontSize="14"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Итог -->
            <Border Grid.Column="1" Background="#2E2E3E"
                    BorderBrush="#555" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="20,0,0,0">
                <StackPanel>
                    <TextBlock Text="ИТОГО" Foreground="#AAA"
                               FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalText}"
                               Foreground="White" FontSize="32"
                               FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding DiscountText}"
                               Foreground="#4CAF50" FontSize="14"
                               HorizontalAlignment="Center"
                               Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Кнопки действий -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="УДАЛИТЬ ПОЗИЦИЮ"
                    Command="{Binding RemoveCommand}"
                    CommandParameter="{Binding SelectedItem.LineNumber, ElementName=LinesGrid}"
                    Height="60" FontSize="16"
                    Background="#FF5722" Foreground="White"
                    BorderThickness="0" Margin="0,0,10,0"
                    Cursor="Hand"/>

            <Button Grid.Column="1"
                    Content="ОТМЕНИТЬ ЧЕК"
                    Command="{Binding CancelCommand}"
                    Height="60" FontSize="16"
                    Background="#9E9E9E" Foreground="White"
                    BorderThickness="0" Margin="0,0,10,0"
                    Cursor="Hand"/>

            <Button Grid.Column="2"
                    Content="ОПЛАТИТЬ"
                    Command="{Binding PayCommand}"
                    Height="60" FontSize="18" FontWeight="Bold"
                    Background="#2196F3" Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
