<Window x:Class="MarkPos.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MarkPos — Касса самообслуживания"
        WindowState="Maximized"
        Background="#1E1E2E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="КАССА САМООБСЛУЖИВАНИЯ"
                   Foreground="White" FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Список товаров -->
        <DataGrid Grid.Row="1"
                  x:Name="LinesGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="#2E2E3E"
                  Foreground="White"
                  RowBackground="#2E2E3E"
                  AlternatingRowBackground="#3E3E4E"
                  BorderBrush="#555"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  FontSize="16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding LineNumber}" Width="50"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Product.Name}" Width="*"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity, StringFormat=F3}" Width="80"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=F2}" Width="100"/>
                <DataGridTextColumn Header="Скидка" Binding="{Binding DiscountSum, StringFormat=F2}" Width="100"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalSum, StringFormat=F2}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Поле сканирования и итог -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Штрихкод -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Отсканируйте товар или введите штрихкод:"
                           Foreground="#AAA" FontSize="14" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="BarcodeInput"
                             Grid.Column="0"
                             FontSize="20"
                             Padding="10"
                             Background="#2E2E3E"
                             Foreground="White"
                             CaretBrush="White"
                             BorderBrush="#555"
                             KeyDown="BarcodeInput_KeyDown"/>
                    <Button Grid.Column="1" Content="Добавить"
                            Margin="10,0,0,0"
                            FontSize="16"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="AddButton_Click"/>
                </Grid>
                <TextBlock x:Name="StatusText"
                           Foreground="#FF6B6B"
                           FontSize="14"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Итог -->
            <Border Grid.Column="1" Background="#2E2E3E"
                    BorderBrush="#555" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="20,0,0,0">
                <StackPanel>
                    <TextBlock Text="ИТОГО" Foreground="#AAA"
                               FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TotalText" Text="0.00 BYN"
                               Foreground="White" FontSize="32"
                               FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="DiscountText" Text=""
                               Foreground="#4CAF50" FontSize="14"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Кнопки действий -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="УДАЛИТЬ ПОЗИЦИЮ"
                    Height="60" FontSize="16"
                    Background="#FF5722" Foreground="White"
                    BorderThickness="0" Margin="0,0,10,0"
                    Cursor="Hand"
                    Click="RemoveButton_Click"/>

            <Button Grid.Column="1" Content="ОТМЕНИТЬ ЧЕК"
                    Height="60" FontSize="16"
                    Background="#9E9E9E" Foreground="White"
                    BorderThickness="0" Margin="0,0,10,0"
                    Cursor="Hand"
                    Click="CancelButton_Click"/>

            <Button Grid.Column="2" Content="ОПЛАТИТЬ"
                    Height="60" FontSize="18" FontWeight="Bold"
                    Background="#2196F3" Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="PayButton_Click"/>
        </Grid>
    </Grid>
</Window>