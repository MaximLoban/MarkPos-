<Window x:Class="MarkPos.UI.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MarkPos.UI"
        Title="MarkPos"
        WindowState="Maximized"
        WindowStyle="None"
        Background="#F5F5F5"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="Green" Color="#8DC640"/>
        <SolidColorBrush x:Key="Dark"  Color="#373C46"/>
        <SolidColorBrush x:Key="Navy"  Color="#1C2D4F"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="586"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════ ЛЕВАЯ ЧАСТЬ ══════════ -->
        <Grid Grid.Column="0" Background="#F5F5F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="90"/>
                <!-- Логотип -->
                <RowDefinition Height="Auto"/>
                <!-- Заголовки -->
                <RowDefinition Height="*"/>
                <!-- Шаги -->
            </Grid.RowDefinitions>

            <!-- Логотип -->
            <Image Grid.Row="0"
           Source="C:\MarketPosSale\data4\Image\MainLogin\logo.png"
           Height="45"
           HorizontalAlignment="Left"
           VerticalAlignment="Center"
           Margin="109,0,0,0"
           Stretch="Uniform"/>

            <!-- Заголовки -->
            <StackPanel Grid.Row="1" Margin="109,0,60,30">
                <TextBlock Text="КАССА САМООБСЛУЖИВАНИЯ."
                   FontFamily="Open Sans" FontWeight="Bold"
                   FontSize="64" Foreground="{StaticResource Dark}"
                   TextWrapping="Wrap"/>
                <TextBlock Text="Покупайте быстро и просто!"
                   FontFamily="Open Sans" FontSize="55"
                   Foreground="{StaticResource Dark}"
                   TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Шаги 1-2-3 через Logo2.png перекрашиваем в зелёный -->
            <Viewbox Grid.Row="2"
         Stretch="Uniform"
         HorizontalAlignment="Left"
         VerticalAlignment="Top"
         Margin="109,20,60,40">
                <Rectangle Width="960" Height="700"
               Fill="{StaticResource Green}">
                    <Rectangle.OpacityMask>
                        <ImageBrush ImageSource="C:\MarketPosSale\data4\Image\MainLogin\Logo2.png"
                        Stretch="Uniform"/>
                    </Rectangle.OpacityMask>
                </Rectangle>
            </Viewbox>

        </Grid>
        <!-- ══════════ ПРАВАЯ ПАНЕЛЬ ══════════ -->
        <Grid Grid.Column="1" Background="White">
            <Grid.Effect>
                <DropShadowEffect BlurRadius="50" ShadowDepth="0"
                                  Color="#1C2D4F" Opacity="0.25"/>
            </Grid.Effect>
            <Grid.RowDefinitions>
                <RowDefinition Height="206"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>

            <!-- Шапка: способы оплаты -->
            <Border Grid.Row="0" Background="{StaticResource Navy}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ДОСТУПНЫЕ СПОСОБЫ ОПЛАТЫ"
                               FontFamily="Roboto" FontSize="20"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>
                    <Image Source="C:\MarketPosSale\data4\Image\MainLogin\PayTypeIcons.png"
                           Height="90" Stretch="Uniform"
                           HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Контент: карта + QR -->
            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="20,0">

                <TextBlock Text="ДЛЯ НАЧАЛА РАБОТЫ"
                           FontFamily="Roboto" FontWeight="Bold"
                           FontSize="40" Foreground="{StaticResource Dark}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock Text="отсканируйте карту «Еплюс»"
                           FontFamily="Roboto" FontSize="32"
                           Foreground="{StaticResource Dark}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,14"/>

                <Image Source="C:\MarketPosSale\data4\Image\MainLogin\DiscountCard.png"
                       Width="233" Height="150"
                       HorizontalAlignment="Center"
                       Stretch="Uniform"
                       Margin="0,0,0,20"/>

                <TextBlock Text="или QR-код из приложения «Еплюс»"
                           FontFamily="Roboto" FontSize="32"
                           Foreground="{StaticResource Dark}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Width="478" TextWrapping="Wrap"
                           Margin="0,0,0,14"/>

                <Image Source="C:\MarketPosSale\data4\Image\MainLogin\QRCode.png"
                       Width="178" Height="178"
                       HorizontalAlignment="Center"
                       Stretch="Uniform"
                       Margin="0,0,0,20"/>

                <TextBlock Text="или нажмите на кнопку ниже"
                           FontFamily="Roboto" FontSize="32"
                           Foreground="{StaticResource Dark}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Width="478" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Кнопка НАЧАТЬ -->
            <Button Grid.Row="2"
        x:Name="StartButton"
        Click="StartButton_Click"
        BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{StaticResource Green}">
                            <TextBlock Text="НАЧАТЬ"
                           FontFamily="Open Sans" FontWeight="Bold"
                           FontSize="64" Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </Grid>
    </Grid>
</Window>