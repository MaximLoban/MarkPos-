<Window x:Class="MarkPos.UI.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MarkPos"
        WindowState="Maximized"
        WindowStyle="None"
        Background="#F5F5F5"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="Green"  Color="#8DC640"/>
        <SolidColorBrush x:Key="Dark"   Color="#373C46"/>
        <SolidColorBrush x:Key="Navy"   Color="#1C2D4F"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="586"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════ ЛЕВАЯ ЧАСТЬ ══════════ -->
        <Grid Grid.Column="0" Background="#F5F5F5">

            <!-- Логотип -->
            <Image Source="https://www.figma.com/api/mcp/asset/44bc7374-0ca1-4402-8900-da09bceb665b"
                   Height="55" HorizontalAlignment="Left" VerticalAlignment="Top"
                   Margin="109,26,0,0" Stretch="Uniform"/>

            <StackPanel Margin="109,158,60,0" VerticalAlignment="Top">

                <TextBlock Text="КАССА САМООБСЛУЖИВАНИЯ."
                           FontFamily="Open Sans" FontWeight="Bold" FontSize="62"
                           Foreground="{StaticResource Dark}" TextWrapping="Wrap"
                           Margin="0,0,0,16"/>

                <TextBlock Text="Покупайте быстро и просто!"
                           FontFamily="Open Sans" FontSize="50"
                           Foreground="{StaticResource Dark}" TextWrapping="Wrap"
                           Margin="0,0,0,50"/>

                <!-- Шаги 1-2-3 -->
                <ItemsControl>
                    <ItemsControl.Items>
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="155"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Width="155" Height="155">
                                <Ellipse Fill="{StaticResource Green}"/>
                                <TextBlock Text="1" FontFamily="Open Sans" FontWeight="Bold"
                                           FontSize="95" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="0,10,0,0"/>
                            </Grid>
                            <TextBlock Grid.Column="1" Text="ПОСТАВЬТЕ КОРЗИНУ"
                                       FontFamily="Open Sans" FontWeight="SemiBold" FontSize="46"
                                       Foreground="{StaticResource Green}"
                                       VerticalAlignment="Center" Margin="36,0,0,0"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="155"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Width="155" Height="155">
                                <Ellipse Fill="{StaticResource Green}"/>
                                <TextBlock Text="2" FontFamily="Open Sans" FontWeight="Bold"
                                           FontSize="95" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="0,10,0,0"/>
                            </Grid>
                            <TextBlock Grid.Column="1" Text="ОТСКАНИРУЙТЕ ШТРИХ-КОД ТОВАРА"
                                       FontFamily="Open Sans" FontWeight="SemiBold" FontSize="46"
                                       Foreground="{StaticResource Green}"
                                       VerticalAlignment="Center" Margin="36,0,0,0"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="155"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Width="155" Height="155">
                                <Ellipse Fill="{StaticResource Green}"/>
                                <TextBlock Text="3" FontFamily="Open Sans" FontWeight="Bold"
                                           FontSize="95" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="0,10,0,0"/>
                            </Grid>
                            <TextBlock Grid.Column="1" Text="ПОЛОЖИТЕ ТОВАР НА ВЕСОВУЮ ПЛАТФОРМУ"
                                       FontFamily="Open Sans" FontWeight="SemiBold" FontSize="46"
                                       Foreground="{StaticResource Green}"
                                       VerticalAlignment="Center" Margin="36,0,0,0"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </ItemsControl.Items>
                </ItemsControl>

            </StackPanel>
        </Grid>

        <!-- ══════════ ПРАВАЯ ПАНЕЛЬ ══════════ -->
        <Grid Grid.Column="1" Background="White">
            <Grid.Effect>
                <DropShadowEffect BlurRadius="50" ShadowDepth="0"
                                  Color="#1C2D4F" Opacity="0.25"/>
            </Grid.Effect>
            <Grid.RowDefinitions>
                <RowDefinition Height="206"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>

            <!-- Шапка: способы оплаты -->
            <Grid Grid.Row="0" Background="{StaticResource Navy}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ДОСТУПНЫЕ СПОСОБЫ ОПЛАТЫ"
                               FontFamily="Roboto" FontSize="20" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Width="110" Margin="8,0">
                            <Image Source="https://www.figma.com/api/mcp/asset/f0e64c17-b6ac-4c5f-94b3-e154e72b63b6"
                                   Height="55" Stretch="Uniform"/>
                            <TextBlock Text="Банковская&#10;карта" FontFamily="Roboto" FontSize="17"
                                       Foreground="{StaticResource Green}" TextAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Width="106" Margin="8,0">
                            <Image Source="https://www.figma.com/api/mcp/asset/a62a2884-442f-4d23-bd6b-17bf91fb7bb0"
                                   Height="55" Stretch="Uniform"/>
                            <TextBlock Text="Мобильный&#10;телефон" FontFamily="Roboto" FontSize="17"
                                       Foreground="{StaticResource Green}" TextAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Width="106" Margin="8,0">
                            <Image Source="https://www.figma.com/api/mcp/asset/6dd57fa8-a4c4-49f7-9f63-bc93a447d9d3"
                                   Height="55" Stretch="Uniform"/>
                            <TextBlock Text="Наличные" FontFamily="Roboto" FontSize="17"
                                       Foreground="{StaticResource Green}" TextAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Width="110" Margin="8,0">
                            <Image Source="https://www.figma.com/api/mcp/asset/98116dc9-1683-4a54-848a-829a604cc192"
                                   Height="55" Stretch="Uniform"/>
                            <TextBlock Text="Приложение&#10;«Еплюс»" FontFamily="Roboto" FontSize="17"
                                       Foreground="{StaticResource Green}" TextAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Контент -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">

                <TextBlock Text="ДЛЯ НАЧАЛА РАБОТЫ"
                           FontFamily="Roboto" FontSize="38" FontWeight="Bold"
                           Foreground="{StaticResource Dark}"
                           HorizontalAlignment="Center" Margin="0,0,0,18"/>

                <TextBlock Text="отсканируйте карту «Еплюс»"
                           FontFamily="Roboto" FontSize="30"
                           Foreground="{StaticResource Dark}"
                           HorizontalAlignment="Center" Margin="0,0,0,14"/>

                <Image Source="https://www.figma.com/api/mcp/asset/dbda2285-50c4-4fd6-b72c-d1cac56c7041"
                       Width="220" Height="140" HorizontalAlignment="Center"
                       Stretch="Uniform" Margin="0,0,0,18"/>

                <TextBlock Text="или QR-код из приложения «Еплюс»"
                           FontFamily="Roboto" FontSize="30"
                           Foreground="{StaticResource Dark}"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Width="460" TextWrapping="Wrap" Margin="0,0,0,14"/>

                <Image Source="https://www.figma.com/api/mcp/asset/e147b923-6a70-4345-8373-d43868988f30"
                       Width="170" Height="170" HorizontalAlignment="Center"
                       Stretch="Uniform" Margin="0,0,0,18"/>

                <TextBlock Text="или нажмите на кнопку ниже"
                           FontFamily="Roboto" FontSize="30"
                           Foreground="{StaticResource Dark}"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Width="460" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Кнопка НАЧАТЬ -->
            <Button Grid.Row="2" x:Name="StartButton" Click="StartButton_Click"
                    BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{StaticResource Green}">
                            <TextBlock Text="НАЧАТЬ  →"
                                       FontFamily="Open Sans" FontWeight="Bold" FontSize="62"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </Grid>
    </Grid>
</Window>