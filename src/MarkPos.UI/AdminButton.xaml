<UserControl x:Class="MarkPos.UI.AdminButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Button BorderThickness="0" Cursor="Hand" Height="75" Width="550">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Border Background="#8DC640" CornerRadius="10" Padding="23,7">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Rectangle Width="60" Height="60"
                                   Fill="#373C46"
                                   Margin="0,0,18,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="C:\MarketPosSale\data4\Image\CreditDoc\Admin.png"
                                            Stretch="Uniform"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <TextBlock Text="ВЫЗОВ АДМИНИСТРАТОРА"
                                   FontFamily="Open Sans" FontWeight="Bold"
                                   FontSize="30" Foreground="#373C46"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Button.Template>
    </Button>
</UserControl>